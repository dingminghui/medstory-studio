{
  "name": "medstory-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.dev -- next dev",
    "build": "dotenv -e .env.prod -- next build",
    "build:dev": "dotenv -e .env.dev -- next build",
    "start": "dotenv -e .env.prod -e .env.local -- next start",
    "start:dev": "dotenv -e .env.dev -e .env.local -- next start",
    "lint": "eslint .",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
